# macOS
**/.DS_Store
.AppleDouble
.LSOverride

# Xcode
**/build/
**/xcuserdata/
**/*.xcuserstate
**/*.xcworkspace/xcuserdata/
**/project.xcworkspace/xcuserdata/
**/xcuserdata/**

# Build artifacts
**/*.o
**/*.a
**/*.build
**/.conformance-cache/

# CMake build trees (PitchFold-style out-of-source dirs)
/build-macos/
/build-ios/
/build/
**/DerivedData/
**/ModuleCache/
**/Pods/

# JUCE build files
**/Builds/**/build/
**/JuceLibraryCode/

# Compiled binaries (exclude build artifacts, allow release versions)
**/Builds/**/build/**/*.component/
**/Builds/**/build/**/*.vst3/
**/Builds/**/build/**/*.au/
**/juce_vst3_helper
~/Library/Audio/Plug-Ins/**

# Code signing for build artifacts (allow in releases)
**/Builds/**/_CodeSignature/

# Log files and temporary files
**/*.log
**/logs/
accent_debug*.log
test_*
debug_*

# Temporary files
**/Temporary*
**/temp/
*.tmp
*.bak
*~

# IDE files
.vscode/
.idea/

# Test binaries
test_accent_*
debug_bjorklund.js
signing.local.cmake

# WebUI build artifacts
Source/WebUI/node_modules/
Source/WebUI/dist/

